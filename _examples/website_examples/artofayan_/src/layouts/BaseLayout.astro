---
import "../styles/global.css";
import { ClientRouter, fade } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BrushCursor from "../components/BrushCursor.astro";

const smoothFade = fade({ duration: "0.4s" });

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ayan Nag",
  jobTitle: "Artist / Illustrator",
  url: "https://artofayan.com",
  sameAs: [
    "https://www.instagram.com/artofayan/",
    "https://www.artstation.com/artofayan",
    "https://payhip.com/artofayan",
  ],
};

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}
const { title, description, ogImage, canonicalUrl } = Astro.props;
const currentPath = Astro.url.pathname;
const site = (Astro.site?.href ?? Astro.url.origin).replace(/\/$/, "");
const canonical = canonicalUrl ?? `${site}${Astro.url.pathname}`;
const defaultOgImage = "/favicon.png";
const resolvedOgImage = ogImage ?? defaultOgImage;
const ogImageAbsolute = resolvedOgImage.startsWith("http")
  ? resolvedOgImage
  : `${site}${resolvedOgImage.startsWith("/") ? resolvedOgImage : `/${resolvedOgImage}`}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preload" href="/fonts/questrial-latin.woff2" as="font" type="font/woff2" crossorigin />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4ede3" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageAbsolute} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zeyada&display=swap" rel="stylesheet">
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>
      (function(){
        // Theme initialization
        function apply(){
          document.documentElement.setAttribute("data-theme","dark");
        }
        apply();
        document.addEventListener("astro:after-swap",apply);
        
        // Global Scroll Reveal Observer - Mellow Timing
        function initObserver() {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                observer.unobserve(entry.target);
              }
            });
          }, { rootMargin: "0px 0px -40px 0px", threshold: 0.1 });
          
          document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
        }
        
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initObserver, { once: true });
        } else {
          initObserver();
        }
        document.addEventListener("astro:page-load", initObserver);
        document.addEventListener("astro:after-swap", initObserver);

        // Crossfade fallback for browsers without View Transitions API
        if (!('startViewTransition' in document)) {
          document.addEventListener("astro:before-swap", (e) => {
            const main = document.querySelector('main');
            if (main) {
              main.style.opacity = '0';
              main.style.transition = 'opacity 0.25s ease';
            }
          });
        }

        // Loading Indicator Logic
        document.addEventListener("astro:before-preparation", () => {
          document.body.classList.add('is-loading');
        });
        document.addEventListener("astro:after-swap", () => {
          document.body.classList.remove('is-loading');
        });
        document.addEventListener("astro:page-load", () => {
          document.body.classList.remove('is-loading');
        });

        // Header Scroll Logic
        function handleHeaderScroll() {
          const header = document.getElementById("site-header");
          if (!header) return;
          if (window.scrollY > 10) {
            header.classList.add("site-header--scrolled");
          } else {
            header.classList.remove("site-header--scrolled");
          }
        }

        // Sync Header Placeholder Height
        function syncHeaderPlaceholder() {
          const header = document.getElementById("site-header");
          const placeholder = document.getElementById("header-placeholder");
          if (header && placeholder) {
            if (!header.classList.contains("site-header--scrolled")) {
              placeholder.style.height = header.offsetHeight + "px";
            } else if (!placeholder.style.height || placeholder.style.height === "0px") {
              header.classList.remove("site-header--scrolled");
              placeholder.style.height = header.offsetHeight + "px";
              if (window.scrollY > 10) header.classList.add("site-header--scrolled");
            }
          }
        }

        document.addEventListener("scroll", handleHeaderScroll, { passive: true });
        window.addEventListener("resize", syncHeaderPlaceholder, { passive: true });
        document.addEventListener("DOMContentLoaded", () => { syncHeaderPlaceholder(); handleHeaderScroll(); });
        document.addEventListener("astro:page-load", () => { syncHeaderPlaceholder(); handleHeaderScroll(); });
      })();
    </script>

  </head>
  <body id="top">
    <div id="loading-bar" class="loading-bar"></div>
    <div id="header-placeholder"></div>
    <header id="site-header" class="site-header">
      <Nav currentPath={currentPath} />
      <slot name="header-bottom" />
    </header>
    <main transition:animate={smoothFade} class="main-fade-in">
      <slot />
    </main>
    <Footer />
    <!-- <BrushCursor /> -->
  </body>
</html>

<style is:global>
  /* Ensure the sticky header can touch the top of the viewport */
  body {
    padding-top: 0 !important;
  }
</style>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 50;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                backdrop-filter 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }


  /* Division between Nav and CategoryBar */
  .site-header :global(.nav-container) {
    background: #1c2323; /* Distinct Teal-Grey Header */
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    height: 5.5rem;
    display: flex;
    align-items: center;
    transition:
      background 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  .site-header :global(.catbar) {
    background: #0d1111; /* Deeper Dark Grey for Catbar */
    border-top: none;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    height: 2.75rem; /* Strict 2:1 ratio with Nav (5.5 / 2.75 = 2) */
    display: flex;
    align-items: center;
    transition:
      background 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .site-header--scrolled {
    background: var(--glass-bg, rgba(13, 17, 17, 0.85));
    backdrop-filter: blur(var(--glass-blur, 30px)) saturate(120%);
    -webkit-backdrop-filter: blur(var(--glass-blur, 30px)) saturate(120%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Fade out individual row backgrounds and shrink padding when glass is active */
  .site-header--scrolled :global(.nav-container) {
    background: transparent !important;
    /* Nav stays the same size as requested */
  }

  .site-header--scrolled :global(.catbar) {
    background: transparent !important;
    border-top-color: transparent;
    height: 1.8rem; /* Catbar shrinks on scroll */
  }

  @media (max-width: 767px) {
    .site-header :global(.nav-container) {
      height: 4.65rem;
    }

    .site-header :global(.catbar) {
      height: 2.45rem;
    }

    .site-header--scrolled :global(.catbar) {
      height: 1.9rem;
    }
  }
</style>

