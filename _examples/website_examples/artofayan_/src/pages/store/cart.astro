---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Cart — Ayan Nag" description="Review your cart before checkout.">
  <section class="cart" aria-labelledby="cart-heading">
    <span class="cart__eyebrow">Cart</span>

    <div class="cart__empty" data-cart-empty hidden>
      <p class="cart__empty-text">Your cart looks empty.</p>
      <a href="/store" class="cart__empty-link">Have a look around the store!→</a>
    </div>

    <ul class="cart__list" data-cart-list></ul>

    <footer class="cart__footer" data-cart-footer hidden>
      <div class="cart__total">
        <span class="cart__total-label">Total</span>
        <span class="cart__total-amount" data-cart-total>$0.00</span>
      </div>
      <a href="#" class="cart__checkout" data-cart-checkout target="_blank" rel="noopener noreferrer">
        Checkout via Payhip ↗
      </a>
      <p class="cart__note">Payment is handled securely by Payhip. Download links by email.</p>
    </footer>
  </section>
</BaseLayout>

<script>
  import { payhipCartUrl, storeProducts } from "../../data/payhip-products";
  import { readCart, removeFromCart } from "../../lib/store-cart";

  const productById = Object.fromEntries(storeProducts.map((p) => [p.productId, p]));

  function parsePrice(price: string): number {
    const match = price.replace(/,/g, "").match(/(\d+(?:\.\d+)?)/);
    return match ? Math.round(Number(match[1]) * 100) : 0;
  }

  function renderCart() {
    const ids = readCart();
    const list = document.querySelector<HTMLUListElement>("[data-cart-list]");
    const empty = document.querySelector<HTMLElement>("[data-cart-empty]");
    const footer = document.querySelector<HTMLElement>("[data-cart-footer]");
    const totalEl = document.querySelector<HTMLElement>("[data-cart-total]");
    const checkout = document.querySelector<HTMLAnchorElement>("[data-cart-checkout]");
    if (!list || !empty || !footer || !totalEl || !checkout) return;

    list.innerHTML = "";
    let centsTotal = 0;

    if (ids.length === 0) {
      empty.hidden = false;
      footer.hidden = true;
      return;
    }

    empty.hidden = true;
    footer.hidden = false;

    ids.forEach((productId) => {
      const product = productById[productId];
      if (!product) return;

      centsTotal += parsePrice(product.price);
      const li = document.createElement("li");
      li.className = "cart__item";
      li.innerHTML = `
        <a href="/store/${product.slug}" class="cart__item-link">
          <img src="${product.image}" alt="" loading="lazy" decoding="async" class="cart__item-img" />
          <div class="cart__item-info">
            <span class="cart__item-title">${product.title}</span>
            ${product.format ? `<span class="cart__item-format">${product.format}</span>` : ""}
            <button type="button" class="cart__remove" data-remove="${product.productId}" aria-label="Remove ${product.title}">Remove</button>
          </div>
        </a>
        <span class="cart__item-price">${product.price}</span>
      `;
      list.appendChild(li);
    });

    totalEl.textContent = `$${(centsTotal / 100).toFixed(2)}`;
    checkout.href = payhipCartUrl(ids);

    list.querySelectorAll<HTMLButtonElement>("[data-remove]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const id = btn.getAttribute("data-remove");
        if (!id) return;
        const item = btn.closest(".cart__item");
        if (item instanceof HTMLElement) {
          item.style.opacity = "0";
          item.style.transition = "opacity 0.3s ease";
          setTimeout(() => {
            removeFromCart(id);
            renderCart();
          }, 300);
        } else {
          removeFromCart(id);
          renderCart();
        }
      });
    });
  }

  renderCart();
  document.addEventListener("astro:page-load", renderCart);
  window.addEventListener("store-cart-updated", renderCart);
</script>

<style is:global>
  .cart {
    width: 100%;
    max-width: 40rem;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 3.5rem) var(--px) 3rem;
  }

  .cart__eyebrow {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 2rem;
  }

  /* Empty state */
  .cart__empty {
    padding-top: min(20vh, 8rem);
    text-align: center;
  }

  .cart__empty-text {
    margin: 0 0 1rem;
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 1rem;
  }

  .cart__empty-link {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--link);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .cart__empty-link:hover {
    color: var(--text);
  }

  /* Item list */
  .cart__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cart__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .cart__item:first-child {
    border-top: 1px solid var(--border);
  }

  .cart__item-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    min-width: 0;
    flex: 1;
  }

  .cart__item-img {
    width: 6rem;
    height: auto;
    display: block;
    flex-shrink: 0;
  }

  .cart__item-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .cart__item-title {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--text);
    line-height: 1.4;
  }

  .cart__item-format {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .cart__remove {
    background: none;
    border: none;
    padding: 0;
    margin-top: 0.25rem;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-dim);
    cursor: pointer;
    text-align: left;
    transition: color 0.3s ease;
  }

  .cart__remove:hover {
    color: var(--text);
  }

  .cart__item-price {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  /* Footer */
  .cart__footer {
    margin-top: 1.5rem;
  }

  .cart__total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .cart__total-label {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .cart__total-amount {
    font-family: var(--font-ui);
    font-size: 1.25rem;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .cart__checkout {
    display: block;
    width: 100%;
    padding: 0.9rem 1rem;
    background: var(--accent);
    color: #121616;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.3s ease;
  }

  .cart__checkout:hover {
    background: color-mix(in srgb, var(--accent) 92%, white);
  }

  .cart__checkout:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .cart__note {
    margin: 1rem 0 0;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 767px) {
    .cart__item-img {
      width: 4.5rem;
    }
  }
</style>
