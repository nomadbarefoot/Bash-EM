---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { storeProducts, getProductHref } from "../../data/payhip-products";

const printImages = [
  { src: "/images/midnight-gleam/web.webp", alt: "Midnight Gleam" },
  { src: "/images/daybreak-valley/image_02.webp", alt: "Daybreak Valley" },
  { src: "/images/moonlit-shrine/image_02.webp", alt: "Moonlit Shrine" },
];
---
<BaseLayout title="Store — Ayan Nag" description="Digital art resources, brushes, and tutorials by Ayan!">
  <div class="catbar" slot="header-bottom">
    <div class="store-catbar-container">
      <p class="catbar__text">Brushes, tutorials, and other goodies here!</p>
    </div>
  </div>

  <section class="store" aria-labelledby="store-heading">
    <h1 class="sr-only" id="store-heading">Store</h1>

    <div class="store__grid">
      {storeProducts.map((product, i) => (
        <a href={getProductHref(product)} class="product">
          <div class="product__image-wrap">
            <img
              src={product.image}
              alt={product.title}
              width={product.width}
              height={product.height}
              loading={i < 2 ? "eager" : "lazy"}
              decoding="async"
              class="product__img"
            />
          </div>
          <div class="product__meta">
            <div class="product__info">
              <span class="product__category">{product.category}</span>
              <h2 class="product__title">{product.title}</h2>
            </div>
            <span class="product__price">{product.price}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="prints">
      <span class="prints__eyebrow">Prints</span>
      <p class="prints__note">Open-edition prints, produced and shipped by INPRNT.</p>
      <div class="prints__images">
        {printImages.map((img) => (
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
            decoding="async"
            class="prints__img"
          />
        ))}
      </div>
      <a
        href="https://www.inprnt.com/gallery/artofayan/"
        target="_blank"
        rel="noopener noreferrer"
        class="prints__link"
      >
        Browse prints on INPRNT ↗
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .store-catbar-container {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    padding-inline: var(--px);
  }

  .catbar :global(.catbar__text) {
    margin: 0;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-align: center;
  }

  .store {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    padding: clamp(1rem, 2vw, 1.5rem) var(--px);
  }

  /* Product grid — 2 columns */
  .store__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .product {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product__image-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    transform: translateZ(0);
  }

  .product__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  @media (hover: hover) and (pointer: fine) {
    .product:hover .product__img {
      transform: scale(1.04);
    }
  }

  .product:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .product__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .product__info {
    min-width: 0;
    flex: 1;
  }

  .product__category {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.35rem;
  }

  .product__title {
    margin: 0;
    color: var(--text);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .product__price {
    flex-shrink: 0;
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 1rem;
    font-variant-numeric: tabular-nums;
  }

  /* Prints section */
  .prints {
    margin-top: 5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .prints__eyebrow {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .prints__note {
    margin: 0 0 1.5rem;
    color: var(--text-dim);
    font-family: var(--font-ui);
    font-size: 1rem;
    line-height: 1.625;
  }

  .prints__images {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    -webkit-overflow-scrolling: touch;
  }

  .prints__img {
    flex: 0 0 auto;
    height: 14rem;
    width: auto;
    display: block;
  }

  .prints__link {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--link);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .prints__link:hover {
    color: var(--text);
  }

  @media (max-width: 767px) {
    .catbar :global(.catbar__text) {
      text-align: left;
    }

    .store__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .prints__img {
      height: 10rem;
    }
  }
</style>
