---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Art of Ayan - Resume"
  description="Ayan Nag — Artist and Illustrator from Jalpaiguri, India."
>
  <div class="about container">
    <section class="about__header">
      <div class="about__photo">
        <img
          src="/PP.png"
          alt="Ayan Nag"
          class="about__photo-img"
          loading="eager"
          width="140"
          height="140"
        />
      </div>
      <p class="about__role">Artist / Illustrator</p>
      <p class="about__location">Jalpaiguri, India</p>

      <div class="about__social">
        <a
          href="mailto:contact@artofayan.com"
          aria-label="Email"
          class="about__social-icon"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
              d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
          >
        </a>
        <a
          href="https://www.artstation.com/artofayan"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="ArtStation"
          class="about__social-icon"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 32 32"
            fill="currentColor"
            ><path
              d="M0 23.63l2.703 4.672c0.552 1.094 1.667 1.781 2.885 1.781h17.943l-3.724-6.453zM32 23.661c0-0.641-0.193-1.245-0.516-1.75l-10.516-18.276c-0.557-1.057-1.656-1.719-2.854-1.719h-5.557l16.24 28.135 2.563-4.432c0.5-0.849 0.641-1.224 0.641-1.958zM17.161 19.047l-7.255-12.568-7.26 12.568z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/artofayan/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="about__social-icon"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44 1.441-.645 1.441-1.44-.645-1.44-1.441-1.44z"
            ></path></svg
          >
        </a>
      </div>
    </section>

    <section class="about__content">
      <h2 class="about__heading">About Me</h2>
      <p>
        I'm Ayan, an artist from India. I'm passionate about exploring,
        observing and bringing my perspective to life through art. I love
        creating new worlds, discovering and expressing beauty in the everyday.
      </p>
      <p>
        I have had the pleasure of working with some amazing studios like Axis
        Studios, Psyop, Passion Pictures, Procreate (Savage), Ubisoft etc.
      </p>
      <p>
        Thank you for taking the time to visit my page and I hope my art brings
        you as much joy as it brings me.
      </p>

      <h2 class="about__heading">Skills</h2>
      <div class="about__skills">
        <span class="about__skill">Illustration</span>
        <span class="about__skill">Visual Development</span>
        <span class="about__skill">Environment Design</span>
        <span class="about__skill">Concept Art</span>
        <span class="about__skill">Plein Air</span>
        <span class="about__skill">Procreate</span>
        <span class="about__skill">Photoshop</span>
        <span class="about__skill">Blender</span>
      </div>
    </section>
  </div>
</BaseLayout>
<style>
  .about {
    max-width: 640px;
    margin: 0 auto;
  }

  .about__header {
    text-align: center;
    padding: 2rem 0 0.75rem;
    margin-bottom: 0;
  }

  .about__photo {
    margin-bottom: 0.75rem;
  }
  .about__photo-img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: inline-block;
    border: 1px solid var(--border);
    background: var(--bg-soft);
    padding: 4px;
  }

  .about__role {
    font-size: 0.79rem;
    font-weight: 555;
    color: var(--accent);
    margin: 0 0 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-shadow: 0 2px 1px rgba(0, 0, 0, 0.8);
  }
  .about__location {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-dim);
    margin: 0 0 1.25rem;
  }

  .about__email-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.72rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }
  .about__email-pill:hover {
    background: var(--accent);
    color: #f4f1ec;
  }

  .about__social {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }
  .about__social-icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--subtitle);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .about__social-icon:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .about__social-icon--artstation {
    color: #13aff0;
  }
  .about__social-icon--instagram {
    color: #e1306c;
  }

  .about__content {
    line-height: 1.7;
  }
  .about__content p {
    margin: 0 0 1rem;
    font-size: 0.92rem;
  }
  .about__heading {
    font-family: var(--font-ui);
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 1rem;
    font-weight: 400;
    margin: 1.5rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
  }
  .about__heading::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .about__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .about__skill {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.67rem;
    color: var(--subtitle);
  }

  @media (max-width: 640px) {
    .about__header {
      padding: 1.5rem 0 0.5rem;
      margin-bottom: 0;
    }

    .about__content p {
      font-size: 0.9rem;
      line-height: 1.75;
    }

    .about__heading {
      font-size: 0.92rem;
      letter-spacing: 0.1em;
    }
  }
</style>
