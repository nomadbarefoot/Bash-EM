---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import CategoryBar from "../components/CategoryBar.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => {
  const orderA = a.data.order ?? 9999;
  const orderB = b.data.order ?? 9999;
  if (orderA !== orderB) return orderA - orderB;
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return (a.data.title ?? "").localeCompare(b.data.title ?? "");
});
---
<BaseLayout title="Art of Ayan" description="Ayan Nag — Artist and Illustrator. Environments, concept art, plein air.">
  <CategoryBar active="portfolio" isHome={true} slot="header-bottom" />
  <GalleryGrid projects={sortedProjects} showFilters={true} />
</BaseLayout>
