---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";
import CategoryBar from "../../components/CategoryBar.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.category === "plein-air" || p.data.categories?.includes("plein-air"))
  .sort((a, b) => {
    const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
    if (yearDiff !== 0) return yearDiff;
    return (a.data.title ?? "").localeCompare(b.data.title ?? "");
  });
---
<BaseLayout
  title="Plein Air — Ayan Nag, Artist & Illustrator"
  description="Plein air paintings and outdoor studies by Ayan Nag."
>
  <CategoryBar active="plein-air" isHome={false} slot="header-bottom" />
  {projects.length > 0 ? (
    <GalleryGrid projects={projects} galleryId="plein-air-grid" />
  ) : (
    <p class="empty">No works yet.</p>
  )}
</BaseLayout>
<style>
  .empty {
    text-align: center;
    color: var(--subtitle);
    font-size: 0.83rem;
    margin-top: 3rem;
  }
</style>
