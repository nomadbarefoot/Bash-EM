---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";
import CategoryBar from "../../components/CategoryBar.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.category === "professional" || p.data.categories?.includes("professional"))
  .sort((a, b) => {
    const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
    if (yearDiff !== 0) return yearDiff;
    return (a.data.title ?? "").localeCompare(b.data.title ?? "");
  });
---
<BaseLayout
  title="Professional Works — Ayan Nag, Artist & Illustrator"
  description="Commercial and studio work by Ayan Nag. Concept art, visual development, illustration."
>
  <CategoryBar active="professional" isHome={false} slot="header-bottom" />
  {projects.length > 0 ? (
    <GalleryGrid projects={projects} galleryId="professional-grid" />
  ) : (
    <p class="empty">No works yet.</p>
  )}
</BaseLayout>
<style>
  .empty {
    text-align: center;
    color: var(--subtitle);
    font-size: 0.83rem;
    margin-top: 3rem;
  }
</style>
