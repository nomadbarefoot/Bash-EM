---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryBar from "../../components/CategoryBar.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.id.endsWith(".md") ? entry.id.slice(0, -3) : entry.id },
  }));
}

function slugFromId(id: string): string {
  return id.endsWith(".md") ? id.slice(0, -3) : id;
}
const { slug } = Astro.params;
const entry = await getEntry("projects", slug as string);
if (!entry) {
  return Astro.redirect("/");
}

const { title, year, description, client, cover, images, category } = entry.data;
const imageList = [cover, ...(images ?? []).filter((img) => img !== cover)];
const allProjects = (await getCollection("projects")).sort((a, b) => {
  const yearDiff = (b.data.year ?? 0) - (a.data.year ?? 0);
  if (yearDiff !== 0) return yearDiff;
  return (a.data.title ?? "").localeCompare(b.data.title ?? "");
});
const currentIndex = allProjects.findIndex((p) => slugFromId(p.id) === slug);
const nextEntry = currentIndex >= 0 && currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1]! : null;
const prevEntry = currentIndex > 0 ? allProjects[currentIndex - 1]! : null;
const moreArtwork = allProjects.filter((p) => slugFromId(p.id) !== slug).slice(0, 3);

import { getCategoryLabel } from "../../utils/categories";
---
<BaseLayout
  title={`Art of Ayan - ${title}`}
  description={description ?? `${title} by Ayan Nag`}
  ogImage={cover}
>
  <CategoryBar active={category} slot="header-bottom" />
  <div class="detail container">
    <div class:list={["detail__images", { "detail__images--carousel": imageList.length > 1 }]}>
      {imageList.length > 1 && (
        <div class="carousel" role="region" aria-label="Project images" tabindex="0">
          <div class="carousel__track">
            {imageList.map((src, i) => (
              <figure class="carousel__slide">
                <img src={src} alt={`${title} (${i + 1})`} class="carousel__img" loading={i === 0 ? "eager" : "lazy"} draggable="false" onerror="this.style.visibility='hidden';this.closest('.carousel__slide')?.classList.add('has-broken-img')" />
              </figure>
            ))}
          </div>
          <button class="carousel__control carousel__control--prev" data-carousel-prev aria-label="Previous image" type="button" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 18-6-6 6-6"></path>
            </svg>
          </button>
          <button class="carousel__control carousel__control--next" data-carousel-next aria-label="Next image" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </button>
          <div class="carousel__controls">
            {imageList.length <= 5 ? (
              <div class="carousel__dots" aria-label="Image navigation">
                {imageList.map((_, i) => (
                  <button class:list={["carousel__dot", { "carousel__dot--active": i === 0 }]} data-slide={i} aria-label={`Image ${i + 1} of ${imageList.length}`} type="button" />
                ))}
              </div>
            ) : (
              <p class="carousel__count" aria-live="polite">
                <span data-carousel-current>1</span>
                <span aria-hidden="true"> / </span>
                <span>{imageList.length}</span>
              </p>
            )}
          </div>
          <button
            class="detail__fullscreen"
            data-lightbox-slug={slug}
            aria-label="View fullscreen"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 3 21 3 21 9"></polyline>
              <polyline points="9 21 3 21 3 15"></polyline>
              <line x1="21" y1="3" x2="14" y2="10"></line>
              <line x1="3" y1="21" x2="10" y2="14"></line>
            </svg>
          </button>
        </div>
      )}
      {imageList.length === 1 && (
        <figure class="detail__figure">
          <img src={imageList[0]} alt={title} class="detail__img" draggable="false" onerror="this.style.visibility='hidden';this.closest('figure')?.classList.add('has-broken-img')" />
          <button
            class="detail__fullscreen"
            data-lightbox-slug={slug}
            aria-label="View fullscreen"
            type="button"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 3 21 3 21 9"></polyline>
              <polyline points="9 21 3 21 3 15"></polyline>
              <line x1="21" y1="3" x2="14" y2="10"></line>
              <line x1="3" y1="21" x2="10" y2="14"></line>
            </svg>
          </button>
        </figure>
      )}
    </div>

    <aside class="detail__sidebar">
      <div class="detail__breadcrumb">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        <a href="/" class="detail__breadcrumb-link">Portfolio</a>
      </div>

      <h1 class="detail__title">{title}</h1>

      {description && <p class="detail__description">{description}</p>}

      <div class="detail__nav">
        {prevEntry && (
          <div class="detail__nav-item detail__nav-item--prev">
            <a href={`/series/${slugFromId(prevEntry.id)}`} class="detail__nav-link" id="prev-link">
              <span class="detail__nav-label">← Previous</span>
              <span class="detail__nav-title">{prevEntry.data.title}</span>
            </a>
          </div>
        )}
        {nextEntry && (
          <div class="detail__nav-item detail__nav-item--next">
            <a href={`/series/${slugFromId(nextEntry.id)}`} class="detail__nav-link" id="next-link">
              <span class="detail__nav-label">Next →</span>
              <span class="detail__nav-title">{nextEntry.data.title}</span>
            </a>
          </div>
        )}
      </div>

      {moreArtwork.length > 0 && (
        <div class="detail__more">
          <h3 class="detail__more-heading">More artwork</h3>
          <div class="detail__more-grid">
            {moreArtwork.map((p) => (
              <a href={`/series/${slugFromId(p.id)}`} class="detail__more-item" data-lightbox-slug={slugFromId(p.id)}>
                <img src={p.data.cover} alt={p.data.title} loading="lazy" draggable="false" onerror="this.style.visibility='hidden';this.closest('.detail__more-item')?.classList.add('has-broken-img')" />
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>
  <script>
    let keyboardNavAttached = false;

    function getActiveCarouselContext() {
      const carousel = document.querySelector(".carousel") as HTMLElement | null;
      if (!carousel) return null;
      const track = carousel.querySelector(".carousel__track") as HTMLElement | null;
      if (!track) return null;
      return { track };
    }

    function initCarousel() {
      document.querySelectorAll(".carousel").forEach((carousel) => {
        const track = carousel.querySelector(".carousel__track") as HTMLElement;
        if (!track || carousel.getAttribute("data-carousel-bound") === "true") return;
        carousel.setAttribute("data-carousel-bound", "true");

        const dots = carousel.querySelectorAll<HTMLButtonElement>(".carousel__dot");
        const currentEl = carousel.querySelector<HTMLElement>("[data-carousel-current]");
        const prevButton = carousel.querySelector<HTMLButtonElement>("[data-carousel-prev]");
        const nextButton = carousel.querySelector<HTMLButtonElement>("[data-carousel-next]");
        const slideCount = track.children.length;

        const getActiveIndex = () => {
          const scrollLeft = track.scrollLeft;
          const slideWidth = track.children[0]?.clientWidth ?? 1;
          return Math.min(slideCount - 1, Math.max(0, Math.round(scrollLeft / slideWidth)));
        };

        const updateState = () => {
          const active = getActiveIndex();
          dots.forEach((d, i) => d.classList.toggle("carousel__dot--active", i === active));
          if (currentEl) currentEl.textContent = String(active + 1);
          if (prevButton) prevButton.disabled = active === 0;
          if (nextButton) nextButton.disabled = active === slideCount - 1;
        };

        const goToSlide = (idx: number) => {
          const slideWidth = track.children[0]?.clientWidth ?? 0;
          if (!slideWidth) return;
          const target = Math.min(slideCount - 1, Math.max(0, idx));
          track.scrollTo({ left: target * slideWidth, behavior: "smooth" });
        };

        track.addEventListener("scroll", updateState, { passive: true });
        dots.forEach((dot) => {
          dot.addEventListener("click", () => {
            const idx = Number(dot.getAttribute("data-slide") ?? 0);
            goToSlide(idx);
          });
        });
        prevButton?.addEventListener("click", () => goToSlide(getActiveIndex() - 1));
        nextButton?.addEventListener("click", () => goToSlide(getActiveIndex() + 1));
        updateState();
      });
    }

    function initKeyboardNav() {
      const handleKey = (e: KeyboardEvent) => {
        const context = getActiveCarouselContext();
        const prev = document.getElementById("prev-link") as HTMLAnchorElement | null;
        const next = document.getElementById("next-link") as HTMLAnchorElement | null;
        if (!context) {
          if (e.key === "ArrowRight" && next) next.click();
          if (e.key === "ArrowLeft" && prev) prev.click();
          return;
        }

        const { track } = context;
        const slideWidth = track.children[0]?.clientWidth ?? 0;
        if (!slideWidth) return;

        if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
          e.preventDefault();
          const direction = e.key === "ArrowRight" ? 1 : -1;
          const current = Math.round(track.scrollLeft / slideWidth);
          const maxIndex = Math.max(0, track.children.length - 1);
          const target = Math.min(maxIndex, Math.max(0, current + direction));
          if (target !== current) {
            track.scrollTo({ left: target * slideWidth, behavior: "smooth" });
            return;
          }

          if (direction > 0 && next) {
            next.click();
          } else if (direction < 0 && prev) {
            prev.click();
          }
        }
      };
      if (!keyboardNavAttached) {
        window.addEventListener("keydown", handleKey);
        keyboardNavAttached = true;
      }
    }

    function initEdgeSwipeNavigation() {
      const context = getActiveCarouselContext();
      if (!context) return;
      const { track } = context;
      const swipeBoundAttr = "data-edge-swipe-bound";
      if (track.getAttribute(swipeBoundAttr) === "true") return;
      track.setAttribute(swipeBoundAttr, "true");

      let touchStartX = 0;
      const threshold = 40;

      track.addEventListener(
        "touchstart",
        (event) => {
          touchStartX = event.touches[0]?.clientX ?? 0;
        },
        { passive: true }
      );

      track.addEventListener(
        "touchend",
        (event) => {
          const endX = event.changedTouches[0]?.clientX ?? 0;
          const deltaX = endX - touchStartX;
          if (Math.abs(deltaX) < threshold) return;

          const slideWidth = track.children[0]?.clientWidth ?? 0;
          if (!slideWidth) return;

          const current = Math.round(track.scrollLeft / slideWidth);
          const maxIndex = Math.max(0, track.children.length - 1);
          const prev = document.getElementById("prev-link") as HTMLAnchorElement | null;
          const next = document.getElementById("next-link") as HTMLAnchorElement | null;

          // Swipe left at the end goes forward to next post.
          if (deltaX < 0 && current >= maxIndex && next) {
            next.click();
          }

          // Swipe right at the start goes back to previous post.
          if (deltaX > 0 && current <= 0 && prev) {
            prev.click();
          }
        },
        { passive: true }
      );
    }

    initCarousel();
    initKeyboardNav();
    initEdgeSwipeNavigation();
    document.addEventListener("astro:page-load", initCarousel);
    document.addEventListener("astro:page-load", initKeyboardNav);
    document.addEventListener("astro:page-load", initEdgeSwipeNavigation);
  </script>
  <script>
    import "photoswipe/style.css";
    import { openProjectLightbox } from "../../lib/lightbox.ts";

    const BOUND = "data-series-lightbox-bound";

    function initLightboxBindings() {
      // Fullscreen button on carousel / single image
      document.querySelectorAll<HTMLButtonElement>(".detail__fullscreen").forEach((btn) => {
        if (btn.getAttribute(BOUND) === "true") return;
        btn.setAttribute(BOUND, "true");
        btn.addEventListener("click", () => {
          const slug = btn.getAttribute("data-lightbox-slug") ?? "";
          if (!slug) return;
          const track = document.querySelector<HTMLElement>(".carousel__track");
          let slideIndex = 0;
          if (track) {
            const slideWidth = (track.children[0] as HTMLElement | undefined)?.clientWidth ?? 1;
            slideIndex = Math.round(track.scrollLeft / slideWidth);
          }
          openProjectLightbox(slug, slideIndex);
        });
      });

      // More artwork thumbnails — open lightbox instead of navigating
      document.querySelectorAll<HTMLAnchorElement>(".detail__more-item[data-lightbox-slug]").forEach((link) => {
        if (link.getAttribute(BOUND) === "true") return;
        link.setAttribute(BOUND, "true");
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const slug = link.getAttribute("data-lightbox-slug") ?? "";
          if (slug) openProjectLightbox(slug);
        });
      });

      // Main image click triggers lightbox
      document.querySelectorAll<HTMLElement>(".carousel__img, .detail__img").forEach((img) => {
        if (img.getAttribute(BOUND) === "true") return;
        img.setAttribute(BOUND, "true");
        img.style.cursor = "zoom-in";
        img.addEventListener("click", () => {
          const btn = document.querySelector<HTMLButtonElement>(".detail__fullscreen");
          const slug = btn?.getAttribute("data-lightbox-slug") ?? "";
          if (!slug) return;
          
          let slideIndex = 0;
          const track = document.querySelector<HTMLElement>(".carousel__track");
          if (track) {
            const slideWidth = (track.children[0] as HTMLElement | undefined)?.clientWidth ?? 1;
            slideIndex = Math.round(track.scrollLeft / slideWidth);
          }
          openProjectLightbox(slug, slideIndex);
        });
      });
    }

    initLightboxBindings();
    document.addEventListener("astro:page-load", initLightboxBindings);
  </script>
</BaseLayout>
<style>
  .detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-top: 2rem;
  }
  @media (min-width: 768px) {
    .detail {
      grid-template-columns: 1.8fr 1fr;
      gap: 2.5rem;
      padding-top: 3rem;
    }
  }

  .detail__images {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Carousel */
  .carousel {
    position: relative;
    outline: none;
  }
  .carousel__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 0;
    scrollbar-width: none;
    max-height: 80vh;
    align-items: flex-start;
  }
  .carousel__track::-webkit-scrollbar {
    display: none;
  }
  .carousel__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    margin: 0;
    position: relative;
  }
  .carousel__slide::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .carousel__img {
    width: 100%;
    height: auto;
    max-height: 80vh;
    object-fit: contain;
    display: block;
    pointer-events: auto;
    transition: opacity 0.8s ease-in-out;
  }
  .carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    margin-top: 0.75rem;
  }
  .carousel__dots {
    display: flex;
    gap: 0.5rem;
  }
  .carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }
  .carousel__dot--active {
    background: var(--accent);
    border-color: var(--accent);
  }
  .carousel__count {
    margin: 0;
    min-width: 4.5rem;
    text-align: center;
    color: var(--subtitle);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }
  .carousel__control {
    position: absolute;
    top: 50%;
    z-index: 12;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.38);
    color: rgba(248, 246, 240, 0.78);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transform: translateY(-50%);
    transition:
      background 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease,
      transform 0.25s ease,
      opacity 0.25s ease;
  }
  .carousel__control--prev {
    left: 0.65rem;
  }
  .carousel__control--next {
    right: 0.65rem;
  }
  .carousel__control:hover:not(:disabled) {
    background: rgba(0, 0, 0, 0.62);
    border-color: rgba(255, 255, 255, 0.24);
    color: #f4f1ec;
    transform: translateY(-50%) scale(1.04);
  }
  .carousel__control:disabled {
    opacity: 0.28;
    cursor: default;
  }
  .detail__figure {
    margin: 0;
    position: relative;
  }
  .detail__figure::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .detail__img {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: auto;
  }

  .detail__sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
  }

  .detail__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--subtitle);
    margin-bottom: 0.75rem;
  }
  .detail__breadcrumb-link {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--subtitle);
    text-decoration: none;
  }
  .detail__breadcrumb-link:hover {
    color: var(--accent);
  }

  .detail__title {
    font-family: var(--font-ui);
    font-size: 1.4rem;
    font-weight: 400;
    margin: 0 0 1rem;
    line-height: 1.3;
    animation: title-entry 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes title-entry {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .detail__description {
    font-size: 0.83rem;
    line-height: 1.65;
    color: var(--text);
    margin: 0 0 1.5rem;
  }

  .detail__nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .detail__nav-item {
    flex: 1;
  }
  .detail__nav-item--next {
    text-align: right;
  }
  .detail__nav-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.3s ease;
  }
  .detail__nav-item--prev .detail__nav-link {
    align-items: flex-start;
  }
  .detail__nav-item--next .detail__nav-link {
    align-items: flex-end;
  }
  .detail__nav-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .detail__nav-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--subtitle);
    margin-bottom: 0.5rem;
  }
  .detail__nav-title {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.4;
    max-width: 200px;
  }

  .detail__more {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .detail__more-heading {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--subtitle);
    margin: 0 0 1rem;
    text-align: center;
  }
  .detail__more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .detail__more-item {
    display: block;
    position: relative;
  }
  .detail__more-item::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .detail__more-item img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }
  .detail__more-item:hover img {
    opacity: 0.75;
  }

  /* Fullscreen button overlaid on carousel / figure */
  .carousel,
  .detail__figure {
    position: relative;
  }
  .detail__fullscreen {
    position: absolute;
    top: 0.65rem;
    right: 0.65rem;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    padding: 0;
    backdrop-filter: blur(4px);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .detail__fullscreen:hover {
    background: rgba(0, 0, 0, 0.7);
    color: #f4f1ec;
  }

  @media (max-width: 767px) {
    .detail {
      gap: 1.5rem;
      padding-top: 1.35rem;
    }

    .detail__sidebar {
      position: static;
    }

    .carousel__control {
      width: 46px;
      height: 46px;
    }

    .carousel__control--prev {
      left: 0.45rem;
    }

    .carousel__control--next {
      right: 0.45rem;
    }

    .detail__title {
      font-size: 1.25rem;
    }

    .detail__description {
      font-size: 0.9rem;
    }
  }
</style>
