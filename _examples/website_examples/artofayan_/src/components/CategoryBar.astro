---
interface Props {
  active?: string;
  isHome?: boolean;
}
const { active = "portfolio", isHome = false } = Astro.props;

const categories = [
  { id: "portfolio", label: "Portfolio", mobileLabel: undefined },
  { id: "environments", label: "Environments", mobileLabel: undefined },
  { id: "plein-air", label: "Plein Air", mobileLabel: undefined },
  { id: "studies", label: "Studies", mobileLabel: undefined },
  { id: "professional", label: "Professional Works", mobileLabel: "Professional" },
];
---

<nav class="catbar" aria-label="Category filter">
  <div class="container container--cat">
    <ul class="catbar__list">
      {
        categories.map((c) => (
          <li class="catbar__item">
            {isHome ? (
              <button
                type="button"
                class:list={[
                  "catbar__link",
                  { "catbar__link--active": c.id === active },
                ]}
                data-filter={c.id}
                data-short-label={c.mobileLabel ? "true" : undefined}
                aria-label={c.label}
              >
                <span class="catbar__label catbar__label--full">{c.label}</span>
                {c.mobileLabel && <span class="catbar__label catbar__label--short">{c.mobileLabel}</span>}
              </button>
            ) : (
              <a
                href={`/?filter=${c.id}`}
                class:list={[
                  "catbar__link",
                  { "catbar__link--active": c.id === active },
                ]}
                data-short-label={c.mobileLabel ? "true" : undefined}
                aria-label={c.label}
              >
                <span class="catbar__label catbar__label--full">{c.label}</span>
                {c.mobileLabel && <span class="catbar__label catbar__label--short">{c.mobileLabel}</span>}
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</nav>
<style>
  .catbar {
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    background: transparent;
    border-bottom: none;
    scroll-padding-inline: var(--px, 16px);
  }
  .container--cat {
    padding: 0 var(--px, 40px);
  }
  .catbar::-webkit-scrollbar {
    display: none;
  }
  .catbar__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    justify-content: flex-start;
    gap: 1.5rem;
  }
  .catbar__item {
    scroll-snap-align: start;
  }
  @media (min-width: 768px) {
    .catbar__list {
      justify-content: flex-end;
      padding-right: 4.5rem;
      gap: 2.5rem;
    }
  }
  .catbar__link {
    font-family: var(--font-ui);
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-dim);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    padding: 0;
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    position: relative;
  }
  .catbar__label--short {
    display: none;
  }
  .catbar__link:hover {
    color: var(--text);
  }
  .catbar__link--active {
    color: var(--accent);
  }
  .catbar__link--active::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--accent);
    transform-origin: center;
    animation: underline-center 0.6s cubic-bezier(0.25, 0.46, 0.45, 1);
  }

  @media (max-width: 767px) {
    .catbar {
      scroll-snap-type: x proximity;
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        rgb(0 0 0) 18px,
        rgb(0 0 0) calc(100% - 30px),
        transparent 100%
      );
      mask-image: linear-gradient(
        to right,
        transparent 0,
        rgb(0 0 0) 18px,
        rgb(0 0 0) calc(100% - 30px),
        transparent 100%
      );
    }

    .container--cat {
      padding: 0 var(--px, 16px);
    }

    .catbar__list {
      gap: 1.1rem;
      width: max-content;
      min-width: 100%;
    }

    .catbar__link {
      min-height: 44px;
      font-size: 0.72rem;
      letter-spacing: 0.1em;
    }
  }

  @media (max-width: 480px) {
    .catbar__link[data-short-label="true"] .catbar__label--full {
      display: none;
    }

    .catbar__link[data-short-label="true"] .catbar__label--short {
      display: inline;
    }
  }
</style>
