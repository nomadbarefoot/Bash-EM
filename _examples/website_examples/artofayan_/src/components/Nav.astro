---
interface Props {
  currentPath?: string;
}
const { currentPath = "" } = Astro.props;
const isStoreRoute = currentPath.startsWith("/store");
const links = [
  { href: "/", label: "Portfolio" },
  { href: "/store", label: "Store" },
  { href: "/about", label: "About" },
];
---
<div class="nav-container" id="nav-container" data-store-route={isStoreRoute ? "true" : undefined}>
  <a href="/" class="nav__brand" aria-label="Ayan Nag home">
    <span class="nav__name">Ayan Nag</span>
    <span class="nav__tagline">Artist / Illustrator</span>
  </a>

  <button class="nav__hamburger" aria-label="Menu" aria-expanded="false" type="button">
    <span class="nav__hamburger-bar"></span>
    <span class="nav__hamburger-bar"></span>
    <span class="nav__hamburger-bar"></span>
  </button>

  <nav class="nav__menu">
    <ul class="nav__list">
      {links.map(({ href, label }) => (
        <li class="nav__item">
          <a
            href={href}
            class:list={["nav__link", { "nav__link--active": href === "/" ? currentPath === "/" : currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="nav__item nav__item--cart-mobile">
        <a href="/store/cart" class="nav__link nav__link--cart-menu">
          View cart
          <span class="nav__cart-dot nav__cart-dot--menu" data-cart-dot-menu hidden aria-hidden="true"></span>
        </a>
      </li>
    </ul>
  </nav>

  <a href="/store/cart" class="nav__cart" aria-label="Store cart" data-cart-icon>
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
    </svg>
    <span class="nav__cart-dot" data-cart-dot hidden aria-hidden="true"></span>
  </a>
</div>
<script>
  import { readCart } from "../lib/store-cart";

  function updateCartIndicator() {
    const count = readCart().length;
    const hasItems = count > 0;

    document.querySelectorAll<HTMLElement>("[data-cart-dot], [data-cart-dot-menu]").forEach((dot) => {
      dot.hidden = !hasItems;
      dot.setAttribute("aria-hidden", hasItems ? "false" : "true");
    });

    const cartIcon = document.querySelector<HTMLElement>("[data-cart-icon]");
    const nav = document.getElementById("nav-container");
    const onStoreRoute = nav?.hasAttribute("data-store-route");

    if (cartIcon) {
      cartIcon.classList.toggle("nav__cart--mobile-visible", hasItems);
    }
  }

  function initNav() {
    const toggle = document.querySelector(".nav__hamburger");
    const nav = document.querySelector(".nav__menu");
    if (!toggle || !nav) return;
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("nav__menu--open");
      document.body.classList.toggle("no-scroll");
    });
    nav.querySelectorAll(".nav__link").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        nav.classList.remove("nav__menu--open");
        document.body.classList.remove("no-scroll");
      });
    });
  }
  initNav();
  updateCartIndicator();
  document.addEventListener("astro:after-swap", initNav);
  document.addEventListener("astro:page-load", updateCartIndicator);
  window.addEventListener("store-cart-updated", updateCartIndicator);
</script>
<style>
  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.85rem var(--px, 40px);
    width: 100%;
  }

  /* Brand */
  .nav__brand {
    flex-shrink: 0;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .nav__brand:hover {
    color: var(--text);
    opacity: 0.9;
    transform: translateY(-1px) scale(1.01);
  }
  .nav__name {
    font-family: var(--font-brand);
    font-size: clamp(2.6rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 0.7;
    letter-spacing: normal;
    text-transform: none;
    color: var(--text);
    transition:
      color 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding-top: 0.25rem;
  }
  .nav__tagline {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--text-dim);
    transition:
      color 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      opacity 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    margin-top: -0.2rem;
    opacity: 0.85;
  }

  /* Nav */
  .nav__menu {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }
  .nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }
  .nav__link {
    font-family: var(--font-ui);
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    display: inline-block;
    transition:
      color 0.3s ease,
      transform 0.3s ease;
  }
  .nav__link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .nav__link--active {
    color: var(--text);
    position: relative;
  }
  .nav__link--active::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--accent);
    transform-origin: center;
    animation: underline-center 0.6s cubic-bezier(0.25, 0.46, 0.45, 1);
  }

  /* Cart icon — bare outline glyph */
  .nav__cart {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    color: var(--text-dim);
    transition: color 0.3s ease;
  }
  .nav__cart:hover {
    color: var(--text);
  }

  /* Rose dot indicator */
  .nav__cart-dot {
    position: absolute;
    top: 0.35rem;
    right: 0.35rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .nav__cart-dot--menu {
    position: static;
    display: inline-block;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  /* Cart in mobile hamburger menu — hidden on desktop */
  .nav__item--cart-mobile {
    display: none;
  }
  .nav__link--cart-menu {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  /* Hamburger (mobile) */
  .nav__hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 5px;
    z-index: 20;
  }
  .nav__hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .nav__hamburger[aria-expanded="true"] .nav__hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__hamburger[aria-expanded="true"] .nav__hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .nav__hamburger[aria-expanded="true"] .nav__hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 767px) {
    .nav-container {
      gap: 1rem;
    }

    .nav__name {
      font-size: clamp(2.1rem, 13vw, 2.55rem);
      line-height: 0.72;
    }

    .nav__tagline {
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      margin-top: -0.1rem;
    }

    .nav__hamburger {
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      min-height: 44px;
      margin-left: auto;
    }
    .nav__menu {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      height: 100dvh;
      z-index: 15;
      background: var(--bg);
      justify-content: center;
      align-items: center;
    }
    .nav__menu--open {
      display: flex;
    }
    .nav__list {
      flex-direction: column;
      gap: 2rem;
    }
    .nav__link {
      font-size: 1.2rem;
    }

    /* Show cart icon on mobile */
    .nav__cart {
      display: none;
      width: 2rem;
      height: 2rem;
      margin-right: 0.25rem;
    }
    .nav__cart--mobile-visible {
      display: flex;
    }
    .nav__cart-dot {
      top: 0;
      right: 0;
    }

    /* Show View cart in hamburger */
    .nav__item--cart-mobile {
      display: list-item;
    }
  }
</style>
