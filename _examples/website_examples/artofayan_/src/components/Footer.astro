<style>
  .footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .footer__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer__copy {
    margin: 0;
    font-size: 0.67rem;
    color: var(--subtitle);
  }
  .footer__back {
    font-size: 0.6rem;
    color: var(--subtitle);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .footer__back:hover {
    color: var(--accent);
  }
  .footer__links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .footer__link {
    color: var(--subtitle);
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
  }
  .footer__link:hover {
    color: var(--accent);
  }
</style>
