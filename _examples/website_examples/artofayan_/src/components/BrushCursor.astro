---
---
<canvas id="brush-canvas" class="brush-canvas" aria-hidden="true"></canvas>
<script>
  function initBrushCursor() {
    const canvas = document.getElementById("brush-canvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let w = 0, h = 0;
    const resize = () => { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; };
    resize();
    window.addEventListener("resize", resize);

    type Point = { x: number; y: number; age: number; size: number; opacity: number };
    const trail: Point[] = [];
    const MAX_AGE = 60;
    let lastX = 0, lastY = 0;
    let rafId = 0;
    let active = false;

    function getAccentRGB(): [number, number, number] {
      const accent = getComputedStyle(document.documentElement).getPropertyValue("--accent").trim() || "#ea6735";
      return [
        parseInt(accent.slice(1, 3), 16) || 234,
        parseInt(accent.slice(3, 5), 16) || 103,
        parseInt(accent.slice(5, 7), 16) || 53,
      ];
    }
    let [r, g, b] = getAccentRGB();
    new MutationObserver(() => { [r, g, b] = getAccentRGB(); })
      .observe(document.documentElement, { attributes: true, attributeFilter: ["style", "data-theme"] });

    document.addEventListener("mousemove", (e) => {
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist > 3) {
        const size = Math.min(12, 3 + dist * 0.15);
        trail.push({ x: e.clientX, y: e.clientY, age: 0, size, opacity: 0.12 });
        if (trail.length > 80) trail.shift();
        lastX = e.clientX;
        lastY = e.clientY;
        if (!active) { active = true; draw(); }
      }
    });

    function draw() {
      if (!ctx) return;
      ctx.clearRect(0, 0, w, h);
      let alive = false;
      for (let i = trail.length - 1; i >= 0; i--) {
        const p = trail[i];
        p.age++;
        if (p.age > MAX_AGE) { trail.splice(i, 1); continue; }
        alive = true;
        const fade = 1 - p.age / MAX_AGE;
        const alpha = p.opacity * fade * fade;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * fade, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx.fill();
      }
      if (alive) { rafId = requestAnimationFrame(draw); }
      else { active = false; ctx.clearRect(0, 0, w, h); }
    }
  }

  if (window.matchMedia("(pointer: fine)").matches) {
    initBrushCursor();
    document.addEventListener("astro:page-load", initBrushCursor);
  }
</script>
<style>
  .brush-canvas {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  @media (pointer: coarse) {
    .brush-canvas { display: none; }
  }

</style>
