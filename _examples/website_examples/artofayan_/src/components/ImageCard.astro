---
interface Props {
  src: string;
  alt: string;
  title: string;
  category: string;
  href?: string;
  width?: number;
  height?: number;
  objectPosition?: string;
}
const { src, alt, title, category, href, width, height, objectPosition } =
  Astro.props;
const imgStyle = objectPosition
  ? `object-position: ${objectPosition}`
  : undefined;
---

<figure class="image-card reveal-on-scroll">
  {
    href ? (
      <a
        href={href}
        class="image-card__link"
        data-pswp-width={width}
        data-pswp-height={height}
        aria-label={title}
      >
        <img
          src={src}
          alt={alt}
          class="image-card__img"
          width={width}
          height={height}
          loading="lazy"
          style={imgStyle}
          draggable="false"
          onerror="this.style.visibility='hidden';this.closest('figure')?.classList.add('has-broken-img')"
        />
        <div class="image-card__overlay" aria-hidden="true">
          <span class="image-card__category">{category}</span>
          <span class="image-card__title">{title}</span>
          <span class="image-card__accent-line"></span>
        </div>
      </a>
    ) : (
      <>
        <img
          src={src}
          alt={alt}
          class="image-card__img"
          width={width}
          height={height}
          loading="lazy"
          style={imgStyle}
          draggable="false"
          onerror="this.style.visibility='hidden';this.closest('figure')?.classList.add('has-broken-img')"
        />
        <div class="image-card__overlay" aria-hidden="true">
          <span class="image-card__category">{category}</span>
          <span class="image-card__title">{title}</span>
          <span class="image-card__accent-line"></span>
        </div>
      </>
    )
  }
</figure>
<style>
  .image-card {
    margin: 0;
    position: relative;
    overflow: hidden;
    break-inside: avoid;
    line-height: 0;
    border-radius: 0; /* Square */
    transform: translateZ(0); /* Force hardware accel */
    height: 100%;
    width: 100%;
  }
  .image-card__link {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
  }
  .image-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      filter 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform, filter;
  }

  :global(.gallery-grid__item:focus-visible) .image-card__img {
    transform: scale(1.04);
    filter: brightness(0.62) saturate(0.92);
  }
  .image-card__link:focus-visible .image-card__img {
    transform: scale(1.04);
    filter: brightness(0.62) saturate(0.92);
  }
  .image-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    padding: clamp(1.1rem, 2.1vw, 2rem);
    pointer-events: none;
    z-index: 2;
    text-align: center;
    background:
      radial-gradient(
        circle at 50% 48%,
        rgba(18, 22, 22, 0.3) 0%,
        rgba(18, 22, 22, 0.18) 44%,
        transparent 72%
      ),
      linear-gradient(
        to bottom,
        rgba(18, 22, 22, 0.14) 0%,
        rgba(18, 22, 22, 0.24) 52%,
        rgba(18, 22, 22, 0.18) 100%
      );
  }

  :global(.gallery-grid__item:focus-visible) .image-card__overlay,
  .image-card__link:focus-visible .image-card__overlay {
    opacity: 1;
  }

  .image-card__category,
  .image-card__title,
  .image-card__accent-line {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.gallery-grid__item:focus-visible) .image-card__category,
  :global(.gallery-grid__item:focus-visible) .image-card__title,
  :global(.gallery-grid__item:focus-visible) .image-card__accent-line,
  .image-card__link:focus-visible .image-card__category,
  .image-card__link:focus-visible .image-card__title,
  .image-card__link:focus-visible .image-card__accent-line {
    opacity: 1;
    transform: translateY(0);
  }

  .image-card__category {
    max-width: min(20rem, 92%);
    margin-bottom: 0.52rem;
    font-size: clamp(0.66rem, 0.82vw, 0.74rem);
    font-weight: 555;
    letter-spacing: 0.15em;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--accent);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.86);
    transition-delay: 0.02s;
  }

  .image-card__title {
    display: -webkit-box;
    max-width: min(24rem, 92%);
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: clamp(1.02rem, 1.35vw, 1.22rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: #f4f1ec;
    line-height: 1.24;
    text-wrap: balance;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.84);
    transition-delay: 0.06s;
  }

  .image-card__accent-line {
    display: block;
    width: 30px;
    height: 2px;
    margin-top: 0.7rem;
    background: var(--accent);
    box-shadow: 0 2px 12px rgba(202, 75, 111, 0.28);
    transition-delay: 0.1s;
  }

  @media (hover: hover) and (pointer: fine) {
    .image-card:hover .image-card__img {
      transform: scale(1.04);
      filter: brightness(0.62) saturate(0.92);
    }

    .image-card:hover .image-card__overlay {
      opacity: 1;
    }

    .image-card:hover .image-card__category,
    .image-card:hover .image-card__title,
    .image-card:hover .image-card__accent-line {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 767px), (hover: none), (pointer: coarse) {
    .image-card__img {
      filter: none;
    }

    .image-card__overlay {
      background: none;
    }

    .image-card__category,
    .image-card__title,
    .image-card__accent-line {
      display: none;
    }
  }
</style>
